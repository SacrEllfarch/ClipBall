{
  "name": "clipball",
  "version": "0.1.0",
  "description": "ClipBall 是一个以悬浮球形态常驻桌面的本地剪贴板历史工具。",
  "main": "src/main/main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node -e \"require((process.env.INIT_CWD || process.cwd()) + '/scripts/start.js')\"",
    "package:win": "node -e \"require((process.env.INIT_CWD || process.cwd()) + '/scripts/package-win.js')\"",
    "check": "node -e \"require((process.env.INIT_CWD || process.cwd()) + '/scripts/check.js')\"",
    "test": "npm run check"
  },
  "keywords": [],
  "author": "",
