{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipBall",
  "version": "0.2.0",
  "identifier": "com.clipball.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ClipBall",
        "width": 72,
        "height": 72,
        "minWidth": 72,
        "minHeight": 72,
        "maxWidth": 380,
        "maxHeight": 540,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "x": null,
        "y": null,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability for ClipBall",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "opener:default",
            "core:window:allow-start-dragging",
            "global-shortcut:allow-is-registered",
            "global-shortcut:allow-register",
            "global-shortcut:allow-unregister",
            "autostart:allow-enable",
            "autostart:allow-disable",
            "autostart:allow-is-enabled"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
